<?xml version="1.0" encoding="utf-8"?>
<Settings>
  <!--
    Full path to mpv.exe. Leave empty to auto-detect from:
    1. PATH environment variable
    2. Scoop: ~/scoop/apps/mpv/current/mpv.exe
    3. Chocolatey: C:\ProgramData\chocolatey\lib\mpv.*\tools\mpv.exe
  -->
  <MpvPath></MpvPath>

  <!--
    Extra command-line arguments passed to mpv.
    --no-border and --wid are always added automatically.
    Default: no OSC, no input bindings, no loop, exit when done.
  -->
  <MpvArgs>--no-osc --no-input-default-bindings --loop-file=no --keep-open=no</MpvArgs>
</Settings>
